{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist/renderer",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "types": ["vite/client"]
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx",
    "src/renderer/**/*.d.ts",
    "src/web/**/*.ts",
    "src/web/**/*.tsx",
    "src/preload/**/*.d.ts",
    "src/shared/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}

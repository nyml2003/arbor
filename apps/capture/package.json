{
  "name": "@arbor/capture",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Capture desktop screenshot tool shell",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "dev:web": "vite dev --configLoader runner --host 127.0.0.1 --port 1420",
    "build:web": "vite build",
    "typecheck:web": "tsc --noEmit",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "typecheck": "pnpm typecheck:web && pnpm check:rust"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3",
    "vite": "^6.4.3",
    "vite-plugin-solid": "^2.11.12"
  }
}

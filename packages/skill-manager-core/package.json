{
  "name": "@arbor/skill-manager-core",
  "version": "0.1.0",
  "type": "module",
  "description": "Arbor agent skill manager core",
  "license": "MIT",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "pnpm run build",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^5.9.3"
  }
}

{
  "name": "@arbor/skills",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Arbor maintained agent skills",
  "scripts": {
    "skill:lint": "node ../skill-manager-cli/dist/cli.js skill lint --cwd .",
    "skill:install:dry-run": "node ../skill-manager-cli/dist/cli.js skill install --cwd . --dry-run",
    "skill:install": "node ../skill-manager-cli/dist/cli.js skill install --cwd .",
    "skill:codex:lint": "node ../skill-manager-cli/dist/cli.js skill lint --manifest ../../.codex/arbor.skills.json --cwd .",
    "skill:codex:install:dry-run": "node ../skill-manager-cli/dist/cli.js skill install --manifest ../../.codex/arbor.skills.json --cwd . --dry-run",
    "skill:codex:install": "node ../skill-manager-cli/dist/cli.js skill install --manifest ../../.codex/arbor.skills.json --cwd ."
  },
  "devDependencies": {
    "@arbor/skill-manager-cli": "workspace:*"
  }
}

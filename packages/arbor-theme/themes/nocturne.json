  "tokenColors": [
    // ── Comments ────────────────────────────────────────
    {
      "name": "Comment",
      "scope": ["comment","punctuation.definition.comment"],
      "settings": {"foreground":"#707888","fontStyle":"italic"}
    },

    // ── Strings (green) ─────────────────────────────────
    {
      "name": "String",
      "scope": ["string","punctuation.definition.string"],
      "settings": {"foreground":"#b8e098"}
    },
    {
      "name": "String Escape / Regexp",
      "scope": ["constant.character.escape","string.regexp"],
      "settings": {"foreground":"#f0b860"}
    },
    {
      "name": "Template expression",
      "scope": ["punctuation.definition.template-expression.begin","punctuation.definition.template-expression.end","punctuation.section.embedded"],
      "settings": {"foreground":"#e8a850"}
    },

    // ── Numbers & Constants (amber) ─────────────────────
    {
      "name": "Boolean / Null",
      "scope": ["constant.language.boolean","constant.language.null"],
      "settings": {"foreground":"#f0b860"}
    },
    {
      "name": "Numeric",
      "scope": ["constant.numeric","constant.language","constant.character"],
      "settings": {"foreground":"#f0b860"}
    },

    // ── Keywords (violet) ───────────────────────────────
    {
      "name": "Control keywords",
      "scope": ["keyword.control","keyword.other"],
      "settings": {"foreground":"#e0b0f8"}
    },
    {
      "name": "Storage keywords",
      "scope": ["storage.type","storage.modifier","storage.type.class","storage.type.function","storage.type.interface"],
      "settings": {"foreground":"#e0b0f8"}
    },

    // ── Types (cyan) ────────────────────────────────────
    {
      "name": "Type / Class names",
      "scope": ["entity.name.type","entity.name.class","entity.name.enum","entity.name.interface","entity.name.trait","support.type","support.type.primitive"],
      "settings": {"foreground":"#60d8e8"}
    },
    {
      "name": "Type alias / Generic",
      "scope": ["entity.name.type.alias","entity.name.type.parameter"],
      "settings": {"foreground":"#60d8e8","fontStyle":"italic"}
    },

    // ── Functions (blue) ────────────────────────────────
    {
      "name": "Function names",
      "scope": ["entity.name.function","entity.name.function.macro","support.function"],
      "settings": {"foreground":"#88c8f8"}
    },
    {
      "name": "Method names",
      "scope": ["entity.name.function.member"],
      "settings": {"foreground":"#88c8f8"}
    },

    // ── Variables (warm white) ──────────────────────────
    {
      "name": "Variable property / member",
      "scope": ["variable.other.property","variable.other.object.property","variable.other.enummember"],
      "settings": {"foreground":"#c8c0b8"}
    },
    {
      "name": "Variables",
      "scope": ["variable","variable.other","variable.other.readwrite","variable.parameter","variable.language"],
      "settings": {"foreground":"#e8e4dc"}
    },

    // ── Operators & Punctuation ─────────────────────────
    {
      "name": "Operators",
      "scope": ["keyword.operator","keyword.operator.comparison","keyword.operator.assignment","keyword.operator.arithmetic","keyword.operator.logical"],
      "settings": {"foreground":"#a8b0b8"}
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation","punctuation.separator","punctuation.terminator","punctuation.section","meta.brace","meta.delimiter"],
      "settings": {"foreground":"#889098"}
    },
    {
      "name": "Punctuation accessor / dot",
      "scope": ["punctuation.accessor","punctuation.separator.period"],
      "settings": {"foreground":"#a8b0b8"}
    },

    // ── Attributes / Annotations (gold) ─────────────────
    {
      "name": "Attributes / Decorators",
      "scope": ["entity.name.type.annotation","entity.name.type.decorator","punctuation.definition.annotation","storage.type.annotation"],
      "settings": {"foreground":"#f0d068"}
    },

    // ── Meta / Preprocessor ─────────────────────────────
    {
      "name": "Preprocessor / Macro",
      "scope": ["meta.preprocessor","keyword.control.directive","keyword.control.import"],
      "settings": {"foreground":"#e0b0f8"}
    },
    {
      "name": "Preprocessor string",
      "scope": ["meta.preprocessor string"],
      "settings": {"foreground":"#b8e098"}
    },

    // ── Markup ──────────────────────────────────────────
    {
      "name": "Markup Bold",
      "scope": ["markup.bold"],
      "settings": {"foreground":"#f0d068","fontStyle":"bold"}
    },
    {
      "name": "Markup Heading",
      "scope": ["markup.heading","markup.heading.markdown","entity.name.section"],
      "settings": {"foreground":"#f0b860","fontStyle":"bold"}
    },
    {
      "name": "Markup Italic",
      "scope": ["markup.italic"],
      "settings": {"foreground":"#e0b0f8","fontStyle":"italic"}
    },
    {
      "name": "Markup Link",
      "scope": ["markup.underline.link","string.other.link","meta.link"],
      "settings": {"foreground":"#60d8e8"}
    },
    {
      "name": "Markup List",
      "scope": ["markup.list","punctuation.definition.list.begin"],
      "settings": {"foreground":"#f0b860"}
    },
    {
      "name": "Markup Quote",
      "scope": ["markup.quote"],
      "settings": {"foreground":"#707888","fontStyle":"italic"}
    },
    {
      "name": "Markup Raw / Code",
      "scope": ["markup.inline.raw","markup.raw"],
      "settings": {"foreground":"#b8e098"}
    },

    // ── JSON / YAML ─────────────────────────────────────
    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json","support.type.property-name"],
      "settings": {"foreground":"#e0b0f8"}
    },

    // ── Entity / Tags (HTML/XML/JSX) ────────────────────
    {
      "name": "Tag attribute names",
      "scope": ["entity.other.attribute-name"],
      "settings": {"foreground":"#e0b0f8"}
    },
    {
      "name": "Tag delimiters",
      "scope": ["punctuation.definition.tag"],
      "settings": {"foreground":"#707888"}
    },
    {
      "name": "Tag names",
      "scope": ["entity.name.tag"],
      "settings": {"foreground":"#60d8e8"}
    },

    // ── CSS / SCSS ──────────────────────────────────────
    {
      "name": "CSS property name",
      "scope": ["support.type.property-name.css"],
      "settings": {"foreground":"#e0b0f8"}
    },
    {
      "name": "CSS property value",
      "scope": ["support.constant.property-value.css"],
      "settings": {"foreground":"#b8e098"}
    },
    {
      "name": "CSS pseudo selectors",
      "scope": ["entity.other.attribute-name.pseudo-class","entity.other.attribute-name.pseudo-element"],
      "settings": {"foreground":"#f0d068"}
    },
    {
      "name": "CSS selectors",
      "scope": ["entity.other.attribute-name.class","entity.other.attribute-name.id"],
      "settings": {"foreground":"#88c8f8"}
    },
    {
      "name": "CSS unit",
      "scope": ["keyword.other.unit"],
      "settings": {"foreground":"#f0b860"}
    },

    // ── Invalid / Errors ────────────────────────────────
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": {"foreground":"#f0d068","fontStyle":"strikethrough"}
    },
    {
      "name": "Invalid",
      "scope": ["invalid","invalid.illegal"],
      "settings": {"foreground":"#f87078","fontStyle":"underline"}
    },

    // ── Misc ────────────────────────────────────────────
    {
      "name": "Documentation comment",
      "scope": ["comment.block.documentation","comment.line.documentation"],
      "settings": {"foreground":"#707888","fontStyle":"italic"}
    }
  ]
}
